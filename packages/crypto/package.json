{
    "name": "@openvault/crypto",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsup src/index.ts --format esm,cjs --dts --clean",
        "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
        "lint": "tsc --noEmit"
    },
    "devDependencies": {
        "tsup": "^8.5.1",
        "typescript": "^5.4.0"
    }
}