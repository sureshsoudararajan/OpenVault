{
  "name": "openvault",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable, open-source cloud storage platform",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n \"api,web\" -c \"magenta,cyan\" \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:generate": "npm run db:generate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "gen-secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}