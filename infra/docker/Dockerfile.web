# ---- Build Stage ----
FROM node:20-alpine AS builder

WORKDIR /app

# Copy root package files
COPY package.json package-lock.json* ./
COPY tsconfig.base.json ./

# Copy ALL package.jsons for workspace resolution
COPY packages/config/package.json ./packages/config/
COPY packages/crypto/package.json ./packages/crypto/
COPY packages/shared-types/package.json ./packages/shared-types/
COPY apps/web/package.json ./apps/web/

# Install dependencies (Cached unless package.jsons change)
RUN npm install --include-workspace-root

# Copy source
COPY packages/ ./packages/
COPY apps/web/ ./apps/web/

# Build
RUN npm run build --workspace=packages/config --workspace=packages/crypto --workspace=packages/shared-types
RUN npm run build --workspace=apps/web

# ---- Production Stage ----
FROM nginx:alpine AS production

WORKDIR /app

COPY --from=builder /app/apps/web/dist/ /usr/share/nginx/html
COPY infra/docker/nginx.web.conf /etc/nginx/conf.d/default.conf

EXPOSE 3000

CMD ["nginx", "-g", "daemon off;"]
